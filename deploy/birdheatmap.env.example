# BirdHeatmap configuration
# Copy this file to /etc/birdheatmap/birdheatmap.env and edit as needed.
# Do NOT quote values (systemd EnvironmentFile does not strip quotes).

STATION_ID=5114
DB_PATH=/var/lib/birdheatmap/birdweather.sqlite
CACHE_PATH=/var/lib/birdheatmap/cache
BIND_HOST=0.0.0.0
BIND_PORT=8765
SYNC_INTERVAL_MINUTES=60

# Set to the date your station first came online (a few days early is fine).
# This controls how far back the initial backfill reaches.
BACKFILL_FROM_DATE=2024-06-01

# Optional tuning — defaults are usually fine:
# BACKFILL_PAGE_SIZE=500
# BACKFILL_RATE_LIMIT_SECONDS=1.0
# BACKFILL_LOG_EVERY_N_PAGES=10
